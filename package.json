{
  "name": "video-studio",
  "version": "0.4.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "remotion:studio": "npx remotion studio remotion/index.ts",
    "remotion:bundle": "npx tsx scripts/bundle.ts",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "postbuild": "cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && echo 'Copied static+public to standalone'",
    "electron:dev": "npm run build && npm run electron:compile && concurrently --kill-others \"npx electron .\"",
    "electron:build": "npm run build && npm run electron:compile && npx electron-builder --config electron-builder.json",
    "electron:publish": "npm run build && npm run electron:compile && npx electron-builder --config electron-builder.json --publish always"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@remotion/bundler": "^4.0.431",
    "@remotion/captions": "^4.0.431",
    "@remotion/cli": "^4.0.431",
    "@remotion/google-fonts": "^4.0.431",
    "@remotion/media-utils": "^4.0.431",
    "@remotion/player": "^4.0.431",
    "@remotion/renderer": "^4.0.431",
    "@remotion/transitions": "^4.0.431",
    "@remotion/zod-types": "^4.0.431",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "^4.0.431",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
