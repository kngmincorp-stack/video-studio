# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# electron build artifacts (prevent 30GB build crash)
*.exe
*.dll
*.dat
*.pak
*.bin
/locales/

# allow build resources (7za.exe for VOICEVOX extraction)
!/resources/
/resources/*
!/resources/7za.exe

# video output
/output/

# generated audio
/public/audio/narration-*.wav

# voicevox engine (downloaded at runtime)
/.voicevox-engine/

# remotion bundle cache
/.remotion/
